<section id="links">
  <h3><%= render partial: 'partials/header_links' %></h3>
</section><br/>

<h3>New Candy Shop</h3><br/>
<%= form_with url:"/shops/#{@shop.id}/discounts", method: :post, local: true do |form| %>
  <%= form.label :percent %>
  <%= form.number_field :percent %><br/><br/>

  <%= form.label :quantity %>
  <%= form.number_field :quantity %><br/><br/>

  <%= form.submit 'Create New Shop' %>
<% end %>
