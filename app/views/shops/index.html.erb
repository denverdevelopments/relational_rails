<section id="links">
  <h3><%= render partial: 'partials/header_links' %></h3>
</section><br/>

<section id="shop-index">
  <h2>Candy Shops Index</h2>
  <% @shops.each do |shop| %>
    <section id="shop-<%= shop.id %>">
      <h4>&emsp;<%= link_to "#{shop.name}", "/shops/#{shop.id}" %>&emsp;&emsp;created _  <%= shop.created_at.strftime("%A, %B %d, %Y") %></h4>
      
      <p>&emsp;&emsp;<%= link_to "EDIT #{shop.name}", "/shops/#{shop.id}/edit" %>&emsp;&emsp;<%= link_to "( Delete )", "/shops/#{shop.id}", method: :delete %></p>
      <br/><br/>
    </section>
  <% end %><br/>
</section>
