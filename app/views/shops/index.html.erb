<section id="links">
  <h3><%= render partial: 'partials/header_links' %></h3>
</section><br/>

<section id="shop-index">
  <h2>Candy Shops Index</h2>
  <% @shops.each do |shop| %>
    <section id="shop-<%= shop.id %>">
      &emsp;<h4><%= link_to "#{shop.name}", "/shops/#{shop.id}" %>&emsp;&emsp;<%= link_to "( Delete )", "/shops/#{shop.id}", method: :delete %></h4>
      <br/><br/>
    </section>
  <% end %><br/>
</section>
