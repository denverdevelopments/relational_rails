<section id="links">
  <h3><%= render partial: 'partials/header_links' %></h3>
</section><br/>

<h2 align="left"><%= @shop.name %></h2>

<p>&emsp;Shop ID#: <%= @shop.id %></p>
<p>&emsp;Sell drinks?: <%= @shop.sells_drinks %></p>
<p>&emsp;How many candy varieties?: <%= @shop.varieties %></p>

<p><%= button_to "Update #{@shop.name}", "/shops/#{@shop.id}/edit", method: :get %></p>
<p><%= button_to "( Delete #{@shop.name} )", "/shops/#{@shop.id}", method: :delete %></p><br/>

<p>&emsp;=> <%= link_to "#{@count_candy}  candy(s) available", "/shops/#{@shop.id}/candies" %></p>
