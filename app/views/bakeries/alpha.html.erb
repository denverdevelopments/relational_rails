<%= link_to "Radical Bakeries", bakeries_path %>
<%= link_to "Delicious Pastries", pastries_path %>
<h1 style="color:tomato;"><%= @bakery.name %></h1>
<%= link_to "New Pastry", "/bakeries/#{@bakery.id}/pastries/new" %>

<section id="pastry-info">
  <% @pastries.each do |pastry| %>
  <section id="pastry-<%= pastry.id %>">
    <h2 style="color:mediumseagreen;"><%= pastry.name %></h2>
    <h3 style="color:darkblue;">The deets:</h3>
    <p style="color:lightblue;">- Savory Pastry: <%= pastry.savory_pastry? %></p>
    <p style="color:lightblue;">- Calorie Amount (don't look): <%= pastry.calories %></p>
  </section>
  <% end %>
</section>
