<%= link_to "Radical Bakeries", bakeries_path %>
<%= link_to "Delicious Pastries", pastries_path %>

<h1 style="color:mediumseagreen;">Fill out the fields below to update your Delicious Pastry</h1>

<%= form_with url: "/pastries/#{@pastry.id}", method: :patch, local: true do |form| %>
  <%= form.label :name %>
  <%= form.text_field :name %>
  <br>
  <%= form.label :savory_pastry %>
  <%= form.select :savory_pastry, [[true], [false]] %>
  <br>
  <%= form.label :calories %>
  <%= form.number_field :calories %>
  <br>
  <%= form.submit 'Update Pastry' %>
<% end %>
